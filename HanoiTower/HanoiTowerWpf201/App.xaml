<Application x:Class="HanoiTowerWpf201.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HanoiTowerWpf201"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="Default_BackColor" Color="#FF181818"/>
        <SolidColorBrush x:Key="Default_ForeColor" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="Default_Blue" Color="#FF3399FF"/>
        <SolidColorBrush x:Key="Default_Orange" Color="#FFFF9933"/>
        <SolidColorBrush x:Key="Phone_Blue" Color="#FF1BA1E2"/>
        <SolidColorBrush x:Key="Phone_Orange" Color="#FFF09609"/>
    </Application.Resources>
</Application>
