<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HanoiTowerWpf"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        x:Class="HanoiTowerWpf.MainWindow"
        mc:Ignorable="d"
        Title="Hanoi Tower" Height="600" Width="900" FontSize="36">
    <Window.Resources>
        <ItemsPanelTemplate x:Key="DisksTemplate">
            <Grid/>
        </ItemsPanelTemplate>
        <DataTemplate x:Key="DiskTemplate">
            <DataTemplate.Resources>
                <Storyboard x:Key="MovedStoryboard">
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MovedTransform" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="00:00:00"/>
                        <EasingDoubleKeyFrame KeyTime="00:00:00.4" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MovedTransform" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="00:00:00"/>
                        <EasingDoubleKeyFrame KeyTime="00:00:00.4" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </DataTemplate.Resources>
            <Rectangle Width="{Binding Width}" Height="30" Fill="#FF33CCFF" Loaded="DiskRectangle_Loaded">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform Y="{Binding Delta.Value.Y}"/>
                        <TranslateTransform X="{Binding Tower.Value.Delta.Value.X}" Y="{Binding Tower.Value.Delta.Value.Y}"/>
                        <TranslateTransform x:Name="MovedTransform"/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
        </DataTemplate>
        <DataTemplate x:Key="TowerTemplate">
            <Rectangle Width="250" Height="30" Fill="#FFFF9933" Cursor="Hand">
                <b:Interaction.Behaviors>
                    <local:MouseDragBehavior Delta="{Binding Delta.Value}"/>
                </b:Interaction.Behaviors>
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform x:Name="DragTransform"/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
        </DataTemplate>
    </Window.Resources>
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid Margin="30">
            <Grid.RenderTransform>
                <TransformGroup>
                    <TranslateTransform X="-300" Y="100"/>
                </TransformGroup>
            </Grid.RenderTransform>
            <ItemsControl ItemTemplate="{DynamicResource DiskTemplate}" ItemsPanel="{DynamicResource DisksTemplate}" ItemsSource="{Binding Disks}"/>
            <ItemsControl ItemTemplate="{DynamicResource TowerTemplate}" ItemsPanel="{DynamicResource DisksTemplate}" ItemsSource="{Binding Towers}"/>
        </Grid>
        <TextBlock Text="{Binding Count.Value}" Margin="50,30" HorizontalAlignment="Right"/>
    </Grid>
</Window>
