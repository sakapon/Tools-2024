<Window x:Class="HanoiTowerWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HanoiTowerWpf"
        mc:Ignorable="d"
        Title="Hanoi Tower" Height="420" Width="900" FontSize="30">
    <Window.Resources>
        <ItemsPanelTemplate x:Key="DisksTemplate">
            <Grid/>
        </ItemsPanelTemplate>
        <DataTemplate x:Key="DiskTemplate">
            <DataTemplate.Resources>
                <Storyboard x:Key="MovedStoryboard">
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MovedTransform" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="00:00:00"/>
                        <EasingDoubleKeyFrame KeyTime="00:00:00.4" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MovedTransform" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="00:00:00"/>
                        <EasingDoubleKeyFrame KeyTime="00:00:00.2" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </DataTemplate.Resources>
            <Rectangle Width="{Binding Width}" Height="30" Fill="#FF33CCFF" RenderTransformOrigin="0.5,0.5" Loaded="DiskRectangle_Loaded">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform Y="{Binding DeltaY.Value}"/>
                        <TranslateTransform X="{Binding Tower.Value.DeltaX.Value}" Y="{Binding Tower.Value.DeltaY.Value}"/>
                        <TranslateTransform x:Name="MovedTransform"/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
        </DataTemplate>
    </Window.Resources>
    <Window.DataContext>
        <local:AppModel/>
    </Window.DataContext>
    <Grid>
        <ItemsControl ItemTemplate="{DynamicResource DiskTemplate}" ItemsPanel="{DynamicResource DisksTemplate}" ItemsSource="{Binding Disks}" Margin="30" RenderTransformOrigin="0.5,0.5">
            <ItemsControl.RenderTransform>
                <TransformGroup>
                    <TranslateTransform X="-300" Y="100"/>
                </TransformGroup>
            </ItemsControl.RenderTransform>
        </ItemsControl>
        <TextBlock Text="{Binding Count.Value}" Margin="30" HorizontalAlignment="Right"/>
    </Grid>
</Window>
