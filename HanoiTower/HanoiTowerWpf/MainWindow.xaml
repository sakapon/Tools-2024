<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HanoiTowerWpf"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        x:Class="HanoiTowerWpf.MainWindow"
        mc:Ignorable="d"
        Title="Tower of Hanoi" Height="600" Width="900" FontSize="36" Background="{DynamicResource Default_BackColor}" Foreground="{DynamicResource Default_ForeColor}">
    <Window.Resources>
        <CubicEase x:Key="CubicEaseOut" EasingMode="EaseOut"/>
        <ItemsPanelTemplate x:Key="DisksTemplate">
            <Grid/>
        </ItemsPanelTemplate>
        <DataTemplate x:Key="DiskTemplate">
            <DataTemplate.Resources>
                <Storyboard x:Key="MovedStoryboard">
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MovedTransform" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="00:00:00"/>
                        <EasingDoubleKeyFrame KeyTime="00:00:00.4" Value="0" EasingFunction="{StaticResource CubicEaseOut}"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MovedTransform" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="00:00:00"/>
                        <EasingDoubleKeyFrame KeyTime="00:00:00.4" Value="0" EasingFunction="{StaticResource CubicEaseOut}"/>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </DataTemplate.Resources>
            <Rectangle Width="{Binding Width}" Height="30" Fill="{DynamicResource Phone_Blue}" RadiusX="6" RadiusY="6" Loaded="DiskRectangle_Loaded">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform Y="{Binding Delta.Value.Y}"/>
                        <TranslateTransform X="{Binding Tower.Value.Delta.Value.X}" Y="{Binding Tower.Value.Delta.Value.Y}"/>
                        <TranslateTransform x:Name="MovedTransform"/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
        </DataTemplate>
        <DataTemplate x:Key="TowerTemplate">
            <Rectangle Width="250" Height="50" Fill="{DynamicResource Phone_Orange}" RadiusX="6" RadiusY="6" Cursor="Hand">
                <b:Interaction.Behaviors>
                    <local:MouseDragBehavior Delta="{Binding Delta.Value}"/>
                </b:Interaction.Behaviors>
            </Rectangle>
        </DataTemplate>
    </Window.Resources>
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <TextBlock Text="{Binding Count.Value}" Margin="50,30" HorizontalAlignment="Right"/>
        <Grid HorizontalAlignment="Left">
            <Grid.RenderTransform>
                <TransformGroup>
                    <TranslateTransform X="25" Y="360"/>
                </TransformGroup>
            </Grid.RenderTransform>
            <ItemsControl ItemTemplate="{DynamicResource DiskTemplate}" ItemsPanel="{DynamicResource DisksTemplate}" ItemsSource="{Binding Disks}" VerticalAlignment="Top"/>
            <ItemsControl ItemTemplate="{DynamicResource TowerTemplate}" ItemsPanel="{DynamicResource DisksTemplate}" ItemsSource="{Binding Towers}" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</Window>
