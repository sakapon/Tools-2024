<Application
    x:Class="HanoiTowerOS102.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:HanoiTowerOS102">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="Default_BackColor" Color="#FF181818"/>
            <SolidColorBrush x:Key="Default_ForeColor" Color="#FFE0E0E0"/>
            <SolidColorBrush x:Key="Phone_Blue" Color="#FF1BA1E2"/>
            <SolidColorBrush x:Key="Phone_Orange" Color="#FFF09609"/>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Theme>
        <mt:ModernTheme CurrentPalette="Dark" xmlns:mt="http://opensilver.net/themes/modern"/>
    </Application.Theme>
</Application>
